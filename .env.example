PORT=3000
BASE_URL=https://your-app.example.com

LOGTO_ENDPOINT=https://your-tenant.logto.app/
LOGTO_APP_ID=your_app_id_here
LOGTO_APP_SECRET=your_app_secret_here
LOGTO_REDIRECT_URI=https://your-app.example.com/callback
LOGTO_POST_LOGOUT_REDIRECT_URI=https://your-app.example.com
LOGTO_M2M_APP_ID=your_m2m_app_id_here
LOGTO_M2M_APP_SECRET=your_m2m_app_secret_here

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_random_session_secret_here
MONGODB_URI=your_mongodb_connection_string_here

DB_NAME=scrabble_dev

# Shared database for user profiles (defaults to 'shared')
SHARED_DB_NAME=shared
